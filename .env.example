# Copy to `.env.local` and fill values. Do NOT commit `.env.local`.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/social_adapt_a2a"
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"

# SecondMe
SECONDME_CLIENT_ID=""
SECONDME_CLIENT_SECRET=""
SECONDME_REDIRECT_URI="http://127.0.0.1:3000/api/auth/callback"
SECONDME_API_BASE_URL="https://api.mindverse.com/gate/lab"

# Zhihu
ZHIHU_APP_KEY=""
ZHIHU_APP_SECRET=""
ZHIHU_API_BASE_URL="https://openapi.zhihu.com"
ZHIHU_RING_IDS="2001009660925334090,2015023739549529606"
# controlled: only logs intent; autonomous: performs publish/comment/react
ZHIHU_PUBLISH_MODE="controlled"

# Optional Neo4j
NEO4J_URI="bolt://127.0.0.1:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD=""
NEO4J_DATABASE="neo4j"

# Simulation
SIM_TICK_INTERVAL_MS="20000"
MIN_WORLD_AGENT_COUNT="10"

