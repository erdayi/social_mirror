generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AgentSource {
  real
  seed
}

enum AgentStatus {
  active
  degraded
  idle
}

enum AgentBehaviorStyle {
  rational
  emotional
  balanced
}

enum AgentStance {
  support
  oppose
  neutral
}

enum ZoneType {
  plaza
  leaderboard
  roundtable
  discussion
}

enum RelationshipType {
  follow
  trust
  cooperate
  reject
  alliance
}

enum SocialEventType {
  move
  inspect_leaderboard
  encounter
  discuss_topic
  join_roundtable
  roundtable_summary
  follow
  trust
  cooperate
  reject
  alliance
  zhihu_pending
}

enum RoundtableStatus {
  match
  invite
  opening
  responses
  summary
  relationship_update
  completed
}

enum GraphNodeType {
  agent
  topic
  roundtable
  zhihu_placeholder_topic
  zone
  knowledge
}

enum GraphEdgeType {
  follows
  trusts
  cooperates
  rejects
  participates_in
  discusses
  mentions
}

enum ZhihuIntegrationState {
  pending_integration
  connected
  error
}

model User {
  id             String   @id @default(cuid())
  secondMeId     String   @unique
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  name           String?
  avatar         String?
  email          String?
  route          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  agent          Agent?

  @@map("users")
}

model Agent {
  id                  String              @id @default(cuid())
  userId              String?             @unique
  user                User?               @relation(fields: [userId], references: [id])
  source              AgentSource
  status              AgentStatus         @default(active)
  displayName         String
  slug                String              @unique
  bio                 String?             @db.Text
  avatarUrl           String?
  pixelRole           String
  pixelPalette        String
  style               AgentBehaviorStyle  @default(balanced)
  stance              AgentStance         @default(neutral)
  currentZone         ZoneType            @default(plaza)
  influence           Int                 @default(0)
  isPlayable          Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  snapshots           AgentSnapshot[]
  zonePresence        ZonePresence?
  outgoingRelations   Relationship[]      @relation("RelationshipSource")
  incomingRelations   Relationship[]      @relation("RelationshipTarget")
  hostedRoundtables   Roundtable[]        @relation("RoundtableHost")
  roundtableTurns     RoundtableTurn[]    @relation("RoundtableSpeaker")
  roundtableMembers   RoundtableParticipant[]
  scores              ScoreSnapshot[]
  actorEvents         SocialEvent[]       @relation("EventActor")
  targetEvents        SocialEvent[]       @relation("EventTarget")
  resourceBalances    AgentResourceBalance[]

  @@index([currentZone])
  @@index([status])
  @@map("agents")
}

model AgentSnapshot {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sourceUserId   String?
  identity       Json
  interests      Json
  memory         Json
  behavior       Json
  extractedTags  Json
  createdAt      DateTime @default(now())

  @@index([agentId, createdAt(sort: Desc)])
  @@map("agent_snapshots")
}

model WorldState {
  id          Int      @id
  tickCount   Int      @default(0)
  status      String   @default("running")
  lastTickAt  DateTime?
  economySnapshot Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("world_state")
}

model AgentResourceBalance {
  id             String   @id @default(cuid())
  agentId        String
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  resourceKey    String
  resourceLabel  String
  producedUnits  Float    @default(0)
  receivedUnits  Float    @default(0)
  sharedUnits    Float    @default(0)
  dividendUnits  Float    @default(0)
  consumedUnits  Float    @default(0)
  investedUnits  Float    @default(0)
  netUnits       Float    @default(0)
  tickNumber     Int?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())

  @@unique([agentId, resourceKey])
  @@index([resourceKey, netUnits(sort: Desc)])
  @@map("agent_resource_balances")
}

model DistrictUpgradePlan {
  id                    String   @id
  districtLabel         String
  title                 String
  description           String?  @db.Text
  requiredResourceKey   String
  requiredResourceLabel String
  requiredUnits         Float
  fundedUnits           Float    @default(0)
  progressPercent       Float    @default(0)
  stage                 String   @default("planning")
  sponsorAgentId        String?
  sponsorAgentName      String?
  tickNumber            Int?
  completedAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([stage, progressPercent(sort: Desc)])
  @@map("district_upgrade_plans")
}

model ZonePresence {
  id        String   @id @default(cuid())
  agentId   String   @unique
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  zone      ZoneType
  x         Int
  y         Int
  mood      String?
  updatedAt DateTime @updatedAt

  @@map("zone_presences")
}

model SocialEvent {
  id             String          @id @default(cuid())
  type           SocialEventType
  actorAgentId   String?
  actorAgent     Agent?          @relation("EventActor", fields: [actorAgentId], references: [id], onDelete: SetNull)
  targetAgentId  String?
  targetAgent    Agent?          @relation("EventTarget", fields: [targetAgentId], references: [id], onDelete: SetNull)
  zone           ZoneType?
  topic          String?
  summary        String?         @db.Text
  roundtableId   String?
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
  @@map("social_events")
}

model Relationship {
  id             String            @id @default(cuid())
  sourceAgentId  String
  sourceAgent    Agent             @relation("RelationshipSource", fields: [sourceAgentId], references: [id], onDelete: Cascade)
  targetAgentId  String
  targetAgent    Agent             @relation("RelationshipTarget", fields: [targetAgentId], references: [id], onDelete: Cascade)
  type           RelationshipType
  strength       Float             @default(0)
  rationale      String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([sourceAgentId, targetAgentId, type])
  @@index([sourceAgentId, type])
  @@index([targetAgentId, type])
  @@map("relationships")
}

model Roundtable {
  id             String                @id @default(cuid())
  hostAgentId    String
  hostAgent      Agent                 @relation("RoundtableHost", fields: [hostAgentId], references: [id], onDelete: Cascade)
  status         RoundtableStatus      @default(match)
  topic          String
  summary        String?               @db.Text
  knowledgeJson  Json?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  participants   RoundtableParticipant[]
  turns          RoundtableTurn[]

  @@index([status])
  @@map("roundtables")
}

model RoundtableParticipant {
  id                 String      @id @default(cuid())
  roundtableId       String
  roundtable         Roundtable  @relation(fields: [roundtableId], references: [id], onDelete: Cascade)
  agentId            String
  agent              Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role               String      @default("guest")
  contributionScore  Float       @default(0)
  joinedAt           DateTime    @default(now())

  @@unique([roundtableId, agentId])
  @@map("roundtable_participants")
}

model RoundtableTurn {
  id             String           @id @default(cuid())
  roundtableId   String
  roundtable     Roundtable       @relation(fields: [roundtableId], references: [id], onDelete: Cascade)
  turnIndex      Int
  stage          RoundtableStatus
  speakerAgentId String?
  speakerAgent   Agent?           @relation("RoundtableSpeaker", fields: [speakerAgentId], references: [id], onDelete: SetNull)
  content        String           @db.Text
  audioUrl       String?          @db.Text
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@unique([roundtableId, turnIndex])
  @@map("roundtable_turns")
}

model ScoreSnapshot {
  id                String   @id @default(cuid())
  agentId           String
  agent             Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  tickNumber        Int
  totalScore        Float
  connectionScore   Float
  trustScore        Float
  cooperationScore  Float
  integrationScore  Float
  rankOverall       Int?
  createdAt         DateTime @default(now())

  @@unique([agentId, tickNumber])
  @@index([tickNumber])
  @@index([tickNumber, totalScore(sort: Desc)])
  @@map("score_snapshots")
}

model GraphNode {
  id        String        @id @default(cuid())
  nodeKey   String        @unique
  nodeType  GraphNodeType
  refId     String?
  label     String
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  outgoing  GraphEdge[]   @relation("GraphEdgeSource")
  incoming  GraphEdge[]   @relation("GraphEdgeTarget")

  @@map("graph_nodes")
}

model GraphEdge {
  id           String        @id @default(cuid())
  edgeType     GraphEdgeType
  sourceNodeId String
  sourceNode   GraphNode     @relation("GraphEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   GraphNode     @relation("GraphEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  weight       Float         @default(0)
  metadata     Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([sourceNodeId, targetNodeId, edgeType])
  @@map("graph_edges")
}

model ZhihuIntegrationStatus {
  id          String                 @id
  label       String
  state       ZhihuIntegrationState  @default(pending_integration)
  description String?                @db.Text
  updatedAt   DateTime               @updatedAt

  @@map("zhihu_integration_status")
}

// A2A Message Model for real user-to-user communication
enum A2AMessageType {
  message
  encounter
  handshake
}

enum A2AMessageStatus {
  pending
  delivered
  read
}

model A2AMessage {
  id          String          @id @default(cuid())
  senderId    String          // Sender Agent ID
  receiverId  String          // Receiver Agent ID
  content     String          @db.Text
  messageType A2AMessageType  @default(message)
  status      A2AMessageStatus @default(pending)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  discussionId String?        // Optional: linked topic discussion

  @@index([receiverId, createdAt])
  @@index([senderId, receiverId])
  @@index([discussionId])
  @@map("a2a_messages")
}

// Topic Discussion - Real users discussing Zhihu hot topics
enum DiscussionStatus {
  opening     // Waiting for participants
  active     // Discussion in progress
  completed  // Discussion ended
}

model TopicDiscussion {
  id            String            @id @default(cuid())
  zhihuTopicId  String            // Linked Zhihu hot topic ID
  title         String            // Topic title (cached)
  excerpt       String?           // Topic excerpt
  heat          Int               @default(0)
  hostAgentId   String            // Agent who started the discussion
  status        DiscussionStatus  @default(opening)
  maxParticipants Int             @default(10)
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  endedAt       DateTime?
  participants  DiscussionParticipant[]

  @@index([status])
  @@index([hostAgentId])
  @@index([createdAt])
  @@map("topic_discussions")
}

model DiscussionParticipant {
  id             String   @id @default(cuid())
  discussionId   String
  discussion     TopicDiscussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  agentId        String
  joinedAt       DateTime @default(now())
  lastActiveAt   DateTime @updatedAt
  isHost         Boolean  @default(false)

  @@unique([discussionId, agentId])
  @@index([discussionId])
  @@index([agentId])
  @@map("discussion_participants")
}
